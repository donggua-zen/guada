# ============================================
# Mock 模式环境变量配置
# ============================================

# 是否启用 Mock 模式 (true/false)
# 注意：仅在开发环境生效，生产环境强制禁用
VITE_ENABLE_MOCK=false

# Mock 场景名称（可选）
# 可用值: NORMAL_TEXT, WITH_THINKING, WITH_TOOL_CALLS, 
#         THINKING_AND_TOOLS, ERROR_TIMEOUT, ERROR_API, LONG_TEXT
VITE_MOCK_SCENARIO=NORMAL_TEXT

# 自定义 Mock 配置（JSON 格式，优先级高于场景名称）
# 示例: {"enableThinking":true,"chunkDelay":50,"customText":"自定义文本"}
# VITE_MOCK_CUSTOM_CONFIG=
