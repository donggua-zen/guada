# ========================================
# GuaDa AI 环境变量配置
# ========================================
#
# 重要提示：
# - Web 环境：直接修改本文件中的配置即可生效
# - Electron 环境：main.ts 中会动态传入环境变量，优先级高于本文件
#   如需修改 Electron 环境的配置，请编辑 electron/main.ts 第 340-357 行
# ========================================

# 数据库配置
DATABASE_URL="file:./data/ai_chat.db"
VECTOR_DB_PATH=./data/vector_db.sqlite

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-2026"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=3000
NODE_ENV=development

# 应用基础 URL（用于生成完整的资源 URL，如图片、文件等）
# 
# 配置说明：
# - Electron 生产环境：设置为 __auto__，系统会在启动时自动检测实际端口并动态设置
# - Electron 开发环境：设置为 http://localhost:3000
# - Web 生产环境：设置为域名或 IP 地址（例如: https://api.example.com 或 http://192.168.1.100:3000）
# - Web 开发环境：可以留空，使用相对路径
#
# 示例：
#   BASE_URL=__auto__                            # Electron 生产环境（自动检测端口）
#   BASE_URL=https://api.yourdomain.com          # Web 生产环境使用域名
#   BASE_URL=http://192.168.1.100:3000           # 局域网使用 IP
#   BASE_URL=                                    # Web 开发环境留空（相对路径）
BASE_URL=http://localhost:3000

# 静态资源配置
STATIC_DIR=./static
STATIC_URL=/static

# 上传文件配置（完全独立于 STATIC_DIR/STATIC_URL）
# UPLOAD_ROOT_DIR: 上传文件的物理存储路径
# UPLOAD_URL_PREFIX: 上传文件的 URL 访问前缀
# 
# 开发环境示例：使用项目内的目录
UPLOAD_ROOT_DIR=./data/uploads
UPLOAD_URL_PREFIX=/uploads
#
# 生产环境示例（Electron）：使用用户数据区
# UPLOAD_ROOT_DIR=C:/Users/xxx/AppData/Roaming/GuaDa/file_stores
# UPLOAD_URL_PREFIX=/uploads



# Token Cache 配置（可选）
# Tokenizer 分词结果缓存配置，用于优化重复文本的 Token 计算性能
# TOKEN_CACHE_MAX_ENTRIES: 最大缓存条目数（默认 10000）
TOKEN_CACHE_MAX_ENTRIES=10000
# TOKEN_CACHE_MAX_MEMORY_MB: 最大内存占用 MB（默认 50）
TOKEN_CACHE_MAX_MEMORY_MB=50
# TOKEN_CACHE_TTL_MS: TTL 过期时间毫秒（默认 1800000 = 30分钟）
TOKEN_CACHE_TTL_MS=1800000
# TOKEN_CACHE_CLEANUP_INTERVAL_MS: 定期清理间隔毫秒（默认 300000 = 5分钟）
TOKEN_CACHE_CLEANUP_INTERVAL_MS=300000

# ========================================
# Electron 环境变量覆盖说明
# ========================================
#
# Electron 应用在启动后端进程时，会通过 process.env 动态传入环境变量。
# 这些变量的优先级高于本 .env 文件中的配置。
#
# 如需修改 Electron 环境的配置，请编辑以下文件：
#   electron/main.ts (第 340-357 行)
#
# Electron 中设置的环境变量包括：
#   - BASE_URL: '__auto__' (自动检测端口)
#   - DATABASE_URL: file:${dbPath} (用户数据区)
#   - VECTOR_DB_PATH: vectorDbPath (用户数据区)
#   - STATIC_DIR: staticDir (应用资源目录)
#   - UPLOAD_ROOT_DIR: uploadDir (用户数据区)
#   - SETTINGS_DIR: userDataPath (用户数据区)
#   - LOGS_DIR: logsDir (用户数据区)
#   - SKILLS_DIR: skillsDir (用户数据区)
#   - WORKSPACE_BASE_DIR: workspaceDir (用户数据区)
#   - ELECTRON_APP: 'true'
#   - BROWSER_BRIDGE_MODE: 'ipc'
#
# Web 环境不受影响，直接使用本文件的配置。
# ========================================
