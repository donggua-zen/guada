generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id               String                 @id @default(cuid())
  title            String?
  userId           String                 @map("user_id")
  // 头像相对路径（如 avatars/session123.jpg），返回前端时转换为完整 URL
  avatarUrl        String?                @map("avatar_url")
  description      String?
  modelId          String?                @map("model_id")
  characterId      String?                @map("character_id")
  settings         Json?
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  lastActiveAt     DateTime?              @map("last_active_at")
  
  // === Bot 会话专用字段 ===
  sessionType      String?                @default("web") @map("session_type")  // "web" | "bot"
  botId            String?                @map("bot_id")                        // Bot 实例ID
  platform         String?                                       // 来源平台: 'qq', 'wechat'
  externalId       String?                @map("external_id")   // 外部会话标识,格式: "platform:type:nativeId"
  // ==================================
  
  memories         Memory[]
  messages         Message[]
  character        Character?             @relation(fields: [characterId], references: [id])
  user             User                   @relation(fields: [userId], references: [id])
  model            Model?                 @relation(fields: [modelId], references: [id])
  contextStates    SessionContextState[]

  @@index([userId])
  @@index([sessionType])
  @@index([botId])
  @@index([platform])
  @@index([externalId])
  @@index([botId, externalId])
  @@map("session")
}

model Message {
  id             String           @id @default(cuid())
  sessionId      String           @map("session_id")
  role           String
  parentId       String?          @map("parent_id")
  currentTurnsId String?          @map("current_turns_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  parent         Message?         @relation("MessageThread", fields: [parentId], references: [id])
  children       Message[]        @relation("MessageThread")
  session        Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contents       MessageContent[]
  files          File[]

  @@index([sessionId])
  @@index([parentId])
  @@index([currentTurnsId])
  @@map("message")
}

model MessageContent {
  id               String   @id @default(cuid())
  messageId        String   @map("message_id")
  turnsId          String   @map("turns_id")
  role             String?
  content          String
  reasoningContent String?  @map("reasoning_content")
  // 预留字段:存储额外的关键字参数(如工具调用信息、元数据等)
  additionalKwargs Json?    @map("additional_kwargs")
  metaData         Json?    @map("meta_data")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([turnsId])
  @@map("message_content")
}

model ModelProvider {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String
  provider   String
  protocol   String?
  apiUrl     String   @map("api_url")
  apiKey     String?  @map("api_key")
  avatarUrl  String?  @map("avatar_url")
  attributes Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  models     Model[]

  @@map("model_provider")
}

model Model {
  id             String          @id @default(cuid())
  name           String?
  providerId     String          @map("provider_id")
  modelName      String          @map("model_name")
  modelType      String          @map("model_type")
  config         Json?           @map("config")
  isFavorite     Boolean         @default(false) @map("is_favorite")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  characters     Character[]
  knowledgeBases KnowledgeBase[]
  provider       ModelProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  sessions       Session[]

  @@map("model")
}

model User {
  id             String          @id @default(cuid())
  role           String?
  // 头像相对路径（如 avatars/user123.jpg），返回前端时转换为完整 URL
  avatarUrl      String?         @map("avatar_url")
  parentId       String?         @map("parent_id")
  nickname       String?
  username       String          @unique
  passwordHash   String          @map("password_hash")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  characters     Character[]
  knowledgeBases KnowledgeBase[]
  sessions       Session[]
  settings       UserSetting?
  mcpServers     McpServer[]
  botInstances   BotInstance[]

  @@map("user")
}

model CharacterGroup {
  id         String      @id @default(cuid())
  name       String
  userId     String      @map("user_id")
  sortOrder  Int         @default(0) @map("sort_order")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  characters Character[]

  @@map("character_group")
}

model Character {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  title       String
  description String?
  // 头像相对路径（如 avatars/char123.jpg），返回前端时转换为完整 URL
  avatarUrl   String?         @map("avatar_url")
  isPublic    Boolean         @default(false) @map("is_public")
  modelId     String?         @map("model_id")
  groupId     String?         @map("group_id")
  settings    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  group       CharacterGroup? @relation(fields: [groupId], references: [id])
  model       Model?          @relation(fields: [modelId], references: [id])
  user        User            @relation(fields: [userId], references: [id])
  sessions    Session[]

  @@map("character")
}

model KnowledgeBase {
  id               String   @id @default(cuid())
  name             String
  description      String?
  userId           String   @map("user_id")
  embeddingModelId String   @map("embedding_model_id")
  chunkMaxSize     Int      @default(1000) @map("chunk_max_size")
  chunkOverlapSize Int      @default(100) @map("chunk_overlap_size")
  chunkMinSize     Int      @default(50) @map("chunk_min_size")
  isActive         Boolean  @default(true) @map("is_active")
  isPublic         Boolean  @default(false) @map("is_public")
  metadataConfig   Json?    @map("metadata_config")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  files            KBFile[]
  embeddingModel   Model    @relation(fields: [embeddingModelId], references: [id])
  user             User     @relation(fields: [userId], references: [id])

  @@map("knowledge_base")
}

model KBFile {
  id                 String        @id @default(cuid())
  knowledgeBaseId    String        @map("knowledge_base_id")
  fileName           String        @map("file_name")
  displayName        String        @map("display_name")
  fileSize           Int           @map("file_size")
  fileType           String        @map("file_type")
  fileExtension      String        @map("file_extension")
  contentHash        String        @map("content_hash")
  filePath           String?       @map("file_path")
  content            String?
  relativePath       String?       @map("relative_path")
  parentFolderId     String?       @map("parent_folder_id")
  isDirectory        Boolean       @default(false) @map("is_directory")
  processingStatus   String        @default("pending") @map("processing_status")
  progressPercentage Int           @default(0) @map("progress_percentage")
  currentStep        String?       @map("current_step")
  errorMessage       String?       @map("error_message")
  totalChunks        Int           @default(0) @map("total_chunks")
  totalTokens        Int           @default(0) @map("total_tokens")
  uploadedAt         DateTime      @default(now()) @map("uploaded_at")
  processedAt        DateTime?     @map("processed_at")
  chunks             KBChunk[]
  knowledgeBase      KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  parent             KBFile?       @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  children           KBFile[]      @relation("FolderHierarchy")

  @@index([knowledgeBaseId])
  @@index([contentHash])
  @@index([processingStatus])
  @@index([parentFolderId])
  @@index([knowledgeBaseId, relativePath]) // 优化按路径查询性能
  @@map("kb_file")
}

model KBChunk {
  id                  String   @id @default(cuid())
  fileId              String   @map("file_id")
  knowledgeBaseId     String   @map("knowledge_base_id")
  content             String
  chunkIndex          Int      @map("chunk_index")
  vectorId            String?  @map("vector_id")
  embeddingDimensions Int?     @map("embedding_dimensions")
  tokenCount          Int      @default(0) @map("token_count")
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")
  file                KBFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([knowledgeBaseId])
  @@index([vectorId])
  @@map("kb_chunk")
}

model Memory {
  id         String    @id @default(cuid())
  sessionId  String    @map("session_id")
  content    String
  category   String    @default("long_term")
  memoryType String    @default("factual") @map("memory_type")
  importance Int       @default(5)
  tags       String?
  metadata   Json?
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([category])
  @@index([memoryType])
  @@map("memory")
}

model File {
  id            String   @id @default(cuid())
  fileName      String   @map("file_name")
  displayName   String   @map("display_name")
  fileSize      Int      @map("file_size")
  fileType      String   @map("file_type")
  fileExtension String   @map("file_extension")
  content       String?
  // 文件相对路径（如 kb/test.pdf），返回前端时转换为完整 URL
  url           String?
  // 预览图相对路径（如 previews/test.jpg），返回前端时转换为完整 URL
  previewUrl    String?  @map("preview_url")
  contentHash   String   @map("content_hash")
  uploadUserId  String?  @map("upload_user_id")
  sessionId     String?  @map("session_id")
  messageId     String?  @map("message_id")
  isPublic      Boolean  @default(false) @map("is_public")
  fileMetadata  Json?    @map("file_metadata")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  message       Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([contentHash])
  @@index([uploadUserId])
  @@index([sessionId])
  @@index([messageId])
  @@map("file")
}

model McpServer {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  headers     Json?
  tools       Json?
  enabled     Boolean  @default(true)
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])

  @@map("mcp_server")
}

model SessionContextState {
  id                      String   @id @default(cuid())
  sessionId               String   @map("session_id")
  summaryContent          String?  @map("summary_content")
  lastCompressedMessageId String?  @map("last_compressed_message_id")
  cleaningStrategy        String?  @map("cleaning_strategy")
  lastCleanedMessageId    String?  @map("last_cleaned_message_id")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  session                 Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_context_state")
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  settings  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_setting")
}

model BotInstance {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")  // 创建者ID
  platform         String                    // 平台类型: 'qq', 'wechat', 'discord'
  name             String                    // 机器人显示名称
  enabled          Boolean  @default(true)   // 是否启用
  
  // 平台特定配置(JSON格式)
  // 包含认证信息(appId, appSecret, token等)和其他平台相关配置(mode, sandbox等)
  platformConfig   Json                      @map("platform_config")
  
  // 预留扩展字段:存储额外的平台特定参数(如webhook URL、回调地址等)
  additionalKwargs Json?                     @map("additional_kwargs")
  
  // 重连配置
  reconnectEnabled Boolean  @default(true)   @map("reconnect_enabled")
  maxRetries       Int      @default(5)      @map("max_retries")
  retryInterval    Int      @default(5000)   @map("retry_interval")  // 毫秒
  
  // 关联的默认角色和模型
  defaultCharacterId String   @map("default_character_id")  // 默认角色ID(必填,用于对话流程)
  defaultModelId     String? @map("default_model_id")
  
  // 状态信息
  status           String   @default("stopped")  // stopped, running, error
  lastStartedAt    DateTime? @map("last_started_at")
  lastError        String?  @map("last_error")
  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  user             User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("bot_instance")
}
